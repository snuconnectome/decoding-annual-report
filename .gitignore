# ============================================================
# CRITICAL: Original PDF contains personal information
# (phone numbers, researcher IDs, signatures, registration nos)
# DO NOT commit anything under source/
# ============================================================
source/*.pdf
source/extracted-text/
!source/.gitkeep

# ============================================================
# Build artifacts (regenerated by make)
# ============================================================
**/build/
!**/build/.gitkeep
*.log
*.aux
*.out

# ============================================================
# Python
# ============================================================
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# ============================================================
# Node / tooling
# ============================================================
node_modules/

# ============================================================
# macOS / editor
# ============================================================
.DS_Store
.idea/
.vscode/
*.swp
*~

# ============================================================
# Claude Code local state (never commit)
# ============================================================
.claude/

# ============================================================
# Sensitive
# ============================================================
.env
.env.local
*.pem
*.key
internal-notes/
private/
